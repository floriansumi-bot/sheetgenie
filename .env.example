# Copy to .env for local dev (`vercel dev`), and set the same vars in the Vercel
# dashboard for production (Project → Settings → Environment Variables).

# Required: your FREE Google Gemini key (primary provider).
# Get one at https://aistudio.google.com  ->  "Get API key"  (no card needed).
GEMINI_API_KEY=

# Optional fallback: xAI Grok key (only tried if Gemini fails). Get one at
# https://x.ai  ->  it is PAID: the account needs credit/a license, or the API
# returns 403. Leave this BLANK to run free on Gemini only (recommended).
XAI_API_KEY=

# Optional: provider order. "gemini" (free only, recommended) or "gemini,grok"
# (adds the paid Grok fallback — only works if XAI_API_KEY has credit).
PROVIDERS=gemini

# Optional: model overrides.
GEMINI_MODEL=gemini-2.5-flash
XAI_MODEL=grok-4.3

# Optional: live web search for current data (Gemini Google-Search grounding).
# Set to "off" to disable.
WEB_SEARCH=on

# Optional: max output tokens for the spec (raise only for very large data fills).
MAX_TOKENS=10000

# Optional: protect /api/health with a shared token (the alert monitor passes it).
HEALTH_TOKEN=

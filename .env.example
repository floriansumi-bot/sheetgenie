# Copy to .env for local dev (`vercel dev`), and set the same vars in the Vercel
# dashboard for production (Project → Settings → Environment Variables).

# Required: your FREE Google Gemini key (primary provider).
# Get one at https://aistudio.google.com  ->  "Get API key"  (no card needed).
GEMINI_API_KEY=

# Recommended FREE fallback: Groq (fast inference of capable open models). Used only
# when Gemini is unavailable, so the app stays up when Gemini's daily quota is spent.
# Get one at https://console.groq.com  ->  "API Keys"  (free, no card needed).
GROQ_API_KEY=

# Optional EXTRA fallback: xAI Grok key. PAID — the account needs credit or the API
# returns 403. Leave BLANK unless you've funded xAI; Gemini+Groq are both free.
XAI_API_KEY=

# Optional: provider order. "gemini,groq" (both free, recommended), "gemini" (only),
# or add ",grok" at the end for the paid xAI fallback.
PROVIDERS=gemini,groq

# Optional: model overrides.
GEMINI_MODEL=gemini-2.5-flash
GROQ_MODEL=llama-3.3-70b-versatile
XAI_MODEL=grok-4.3

# Optional: live web search for current data (Gemini Google-Search grounding).
# Set to "off" to disable.
WEB_SEARCH=on

# Optional: max output tokens for the spec (raise only for very large data fills).
MAX_TOKENS=10000

# Optional: protect /api/health with a shared token (the alert monitor passes it).
HEALTH_TOKEN=

# Optional self-hosted "last resort" worker (e.g. a Raspberry Pi running a local LLM).
# When set, and all cloud providers are busy, the app offers to email the result and
# /api/queue hands the job to this worker. Leave BLANK to disable. See pi/README.md.
PI_WORKER_URL=
PI_WORKER_SECRET=

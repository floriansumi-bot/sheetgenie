# Copy to .env for local dev (`vercel dev`), and set the same vars in the Vercel
# dashboard for production (Project → Settings → Environment Variables).

# Required: your Anthropic API key (sk-ant-...). Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional: which model powers the "improve" step. Default is the most capable.
# If your key can't access a model, the app auto-falls back to the next one down:
#   claude-fable-5    -> most capable, best results (default)  [$10/$50 per 1M tokens]
#   claude-opus-4-8   -> excellent, ~half the cost             [ $5/$25 per 1M tokens]
#   claude-sonnet-4-6 -> very good, cheaper still              [ $3/$15 per 1M tokens]
#   claude-haiku-4-5  -> cheapest / fastest                    [ $1/$5  per 1M tokens]
MODEL=claude-fable-5

# Optional: reasoning effort — low | medium | high | max (higher = better/slower/pricier).
EFFORT=high

# Optional: max output tokens for the spec (raise only for very large data fills).
MAX_TOKENS=10000
